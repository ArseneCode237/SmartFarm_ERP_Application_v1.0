{
  "info": {
    "name": "SmartFarm ERP - Module Animaux (Tests)",
    "description": "Collection Postman corrigée pour le module animaux (élevage porcin).\n\nCorrections vs version précédente :\n- provenance corrigée (ACHAT_EXTERNE / NAISSANCE_INTERNE)\n- retrait du PUT /porcs/{id} inexistant\n- ajout du cycle Saillie (créer/confirmer/avortement/alertes)\n- ajout des tests d'isolation par ferme (?fermeId)\n- ajout du module Déclarations Bandes (mortalité, vente, réforme avec stats et historique\n\nBase URL : utilisez http://localhost:8083 (service direct) pour éviter les timeouts gateway,\nou http://localhost:8080 (gateway) si Eureka est démarré.\n\nAstuce : lancez les dossiers dans l'ordre : 0_Init -> 1_Saillies -> 2_MisesBas -> 3_IsolationFerme -> 6_Declarations_Bandes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8083" },
    { "key": "authToken", "value": "YOUR_BEARER_TOKEN" },
    { "key": "truieId", "value": "1" },
    { "key": "verratId", "value": "2" },
    { "key": "saillieId", "value": "1" },
    { "key": "miseBaId", "value": "1" },
    { "key": "porcinId", "value": "1" },
    { "key": "animalId", "value": "1" },
    { "key": "bandeId", "value": "1" },
    { "key": "declarationId", "value": "1" },
    { "key": "structureId", "value": "1" },
    { "key": "siteId", "value": "1" },
    { "key": "fermeIdA", "value": "1" },
    { "key": "fermeIdB", "value": "2" }
  ],
  "item": [
    {
      "name": "0_Init",
      "item": [
        {
          "name": "Créer une truie (FEMELLE)",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('status 201', () => pm.response.to.have.status(201));", "const d = pm.response.json().data; if (d && d.id) pm.environment.set('truieId', d.id);"] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"nom\": \"Truie Bélinda\",\n  \"race\": \"Large White\",\n  \"sexe\": \"FEMELLE\",\n  \"dateEntree\": \"2026-07-01\",\n  \"poidsEntreeKg\": 130.0,\n  \"siteId\": {{siteId}},\n  \"structureId\": {{structureId}},\n  \"provenance\": \"ACHAT_EXTERNE\",\n  \"fournisseurNom\": \"Elevage Test\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/animaux/porcs", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "porcs"] }
          }
        },
        {
          "name": "Créer un verrat (MALE)",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('status 201', () => pm.response.to.have.status(201));", "const d = pm.response.json().data; if (d && d.id) pm.environment.set('verratId', d.id);"] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"nom\": \"Verrat Max\",\n  \"race\": \"Piétrain\",\n  \"sexe\": \"MALE\",\n  \"dateEntree\": \"2026-07-01\",\n  \"poidsEntreeKg\": 150.0,\n  \"siteId\": {{siteId}},\n  \"structureId\": {{structureId}},\n  \"provenance\": \"ACHAT_EXTERNE\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/animaux/porcs", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "porcs"] }
          }
        },
        {
          "name": "Créer une bande porcine",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('status 201', () => pm.response.to.have.status(201));", "const d = pm.response.json().data; if (d && d.id) pm.environment.set('bandeId', d.id);"] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"nom\": \"Bande Engraissement A\",\n  \"espece\": \"PORC\",\n  \"race\": \"Large White\",\n  \"typeProduction\": \"VIANDE\",\n  \"siteId\": {{siteId}},\n  \"structureId\": {{structureId}},\n  \"provenance\": \"ACHAT_EXTERNE\",\n  \"dateEntree\": \"2026-07-01\",\n  \"effectifInitial\": 15\n}" },
            "url": { "raw": "{{baseUrl}}/api/animaux/bandes", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "bandes"] }
          }
        }
      ]
    },
    {
      "name": "1_Saillies",
      "item": [
        {
          "name": "Enregistrer une saillie",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('status 201', () => pm.response.to.have.status(201));", "const d = pm.response.json().data; if (d && d.id) pm.environment.set('saillieId', d.id);"] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"truieId\": {{truieId}},\n  \"verratId\": {{verratId}},\n  \"typeSaillie\": \"NATURELLE\",\n  \"dateSaillie\": \"2026-07-05\",\n  \"operateurNom\": \"Jean\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/animaux/porcs/saillies", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "porcs", "saillies"] }
          }
        },
        {
          "name": "Confirmer la gestation (échographie J+28)",
          "request": {
            "method": "PATCH",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"statut\": \"CONFIRMEE\",\n  \"dateEcho\": \"2026-08-02\",\n  \"operateurNom\": \"Veto\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/animaux/porcs/saillies/{{saillieId}}/confirmation", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "porcs", "saillies", "{{saillieId}}", "confirmation"] }
          }
        },
        {
          "name": "Historique saillies d'une truie",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/animaux/porcs/saillies/truie/{{truieId}}", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "porcs", "saillies", "truie", "{{truieId}}"] }
          }
        },
        {
          "name": "Stats fertilité verrat",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/animaux/porcs/saillies/verrat/{{verratId}}", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "porcs", "saillies", "verrat", "{{verratId}}"] }
          }
        },
        {
          "name": "Alertes échographie attendue (>28j)",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/animaux/porcs/saillies/alertes/echo-attendu", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "porcs", "saillies", "alertes", "echo-attendu"] }
          }
        },
        {
          "name": "Avortement (cas erreur)",
          "request": {
            "method": "PATCH",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"notes\": \"avortement accidentel\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/animaux/porcs/saillies/{{saillieId}}/avortement", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "porcs", "saillies", "{{saillieId}}", "avortement"] }
          }
        }
      ]
    },
    {
      "name": "2_MisesBas",
      "item": [
        {
          "name": "Déclarer une mise-bas (crée les porcelets)",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('status 201', () => pm.response.to.have.status(201));", "const d = pm.response.json().data; if (d && d.id) pm.environment.set('miseBaId', d.id);"] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"nom\": \"Portée #1 de Truie Bélinda\",\n  \"truieId\": {{truieId}},\n  \"saillieId\": {{saillieId}},\n  \"dateMiseBasReelle\": \"2026-11-15T08:30:00\",\n  \"dureeMiseBaMinutes\": 180,\n  \"typeMiseBas\": \"NATURELLE\",\n  \"nbNesVivants\": 12,\n  \"nbMortNes\": 1,\n  \"nbMomifies\": 0,\n  \"poidsMoyenNaissanceKg\": 1.35,\n  \"poidsMinNaissanceKg\": 1.10,\n  \"poidsMaxNaissanceKg\": 1.60,\n  \"nbPorceletsAllaites\": 11,\n  \"bandeDestinationId\": {{bandeId}},\n  \"veterinaireNom\": \"Dr Dupont\",\n  \"operateurNom\": \"Admin\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/animaux/porcs/mises-bas", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "porcs", "mises-bas"] }
          }
        },
        {
          "name": "Détail d'une mise-bas",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/animaux/porcs/mises-bas/{{miseBaId}}", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "porcs", "mises-bas", "{{miseBaId}}"] }
          }
        },
        {
          "name": "Enregistrer le sevrage",
          "request": {
            "method": "PATCH",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"dateSevrageReel\": \"2026-12-06\",\n  \"nbSevres\": 11,\n  \"poidsMoyenSevrageKg\": 7.2,\n  \"bandeDestinationId\": {{bandeId}},\n  \"operateurNom\": \"Admin\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/animaux/porcs/mises-bas/{{miseBaId}}/sevrage", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "porcs", "mises-bas", "{{miseBaId}}", "sevrage"] }
          }
        },
        {
          "name": "Historique portées d'une truie",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/animaux/porcs/mises-bas/truie/{{truieId}}", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "porcs", "mises-bas", "truie", "{{truieId}}"] }
          }
        },
        {
          "name": "Alertes mises-bas imminentes",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/animaux/porcs/mises-bas/alertes/imminentes", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "porcs", "mises-bas", "alertes", "imminentes"] }
          }
        },
        {
          "name": "Alertes sevrages à faire",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/animaux/porcs/mises-bas/alertes/sevrages", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "porcs", "mises-bas", "alertes", "sevrages"] }
          }
        }
      ]
    },
    {
      "name": "3_IsolationFerme",
      "item": [
        {
          "name": "Lister bandes ferme A (isolation)",
          "event": [
            { "listen": "test", "script": { "exec": ["const d = pm.response.json();", "pm.test('ne renvoie que la ferme A', () => {", "  // vérification manuelle : totalElements doit correspondre aux bandes de fermeIdA", "  pm.expect(d).to.have.property('content');"] } }
          ],
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/animaux/bandes?fermeId={{fermeIdA}}&page=0&size=50", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "bandes"], "query": [ { "key": "fermeId", "value": "{{fermeIdA}}" }, { "key": "page", "value": "0" }, { "key": "size", "value": "50" } ] }
          }
        },
        {
          "name": "Lister bandes ferme B (doit être différent)",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/animaux/bandes?fermeId={{fermeIdB}}&page=0&size=50", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "bandes"], "query": [ { "key": "fermeId", "value": "{{fermeIdB}}" }, { "key": "page", "value": "0" }, { "key": "size", "value": "50" } ] }
          }
        },
        {
          "name": "Lister porcs ferme A (dashboard)",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/animaux/porcs/dashboard?fermeId={{fermeIdA}}", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "porcs", "dashboard"], "query": [ { "key": "fermeId", "value": "{{fermeIdA}}" } ] }
          }
        },
        {
          "name": "Sous-performeurs ferme A",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/animaux/pesees/sous-performeurs?fermeId={{fermeIdA}}", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "pesees", "sous-performeurs"], "query": [ { "key": "fermeId", "value": "{{fermeIdA}}" } ] }
          }
        },
        {
          "name": "Alertes ferme A",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/animaux/alertes/ferme/{{fermeIdA}}", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "alertes", "ferme", "{{fermeIdA}}"] }
          }
        }
      ]
    },
    {
      "name": "4_Porcs_Autres",
      "item": [
        {
          "name": "Lister les porcins",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/animaux/porcs", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "porcs"] }
          }
        },
        {
          "name": "Voir un porcin",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/animaux/porcs/{{porcinId}}", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "porcs", "{{porcinId}}"] }
          }
        },
        {
          "name": "Changer statut reproductif (matrice)",
          "request": {
            "method": "PATCH",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"statut\": \"EN_ATTENTE_SAILLIE\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/animaux/porcs/{{porcinId}}/statut", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "porcs", "{{porcinId}}", "statut"] }
          }
        },
        {
          "name": "Transférer un porcin",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"structureDestinationId\": 2,\n  \"motif\": \"Transfert maternité\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/animaux/porcs/{{porcinId}}/transfert", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "porcs", "{{porcinId}}", "transfert"] }
          }
        },
        {
          "name": "Réformer un porcin",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"motif\": \"5ème portée atteinte\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/animaux/porcs/{{porcinId}}/reformer", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "porcs", "{{porcinId}}", "reformer"] }
          }
        },
        {
          "name": "Carrière d'un porcin",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/animaux/porcs/{{porcinId}}/carriere", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "porcs", "{{porcinId}}", "carriere"] }
          }
        }
      ]
    },
    {
      "name": "5_Animaux_Bandes",
      "item": [
        {
          "name": "Créer un animal individuel",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"codeBoucle\": \"ANIMAL-001\",\n  \"espece\": \"PORC\",\n  \"sexe\": \"MALE\",\n  \"race\": \"Landrace\",\n  \"dateNaissance\": \"2025-01-10\",\n  \"dateEntree\": \"2025-01-12\",\n  \"poidsEntreeKg\": 25.0,\n  \"modeSuivi\": \"INDIVIDUEL\",\n  \"structureId\": {{structureId}},\n  \"provenance\": \"NAISSANCE_INTERNE\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/animaux/animaux", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "animaux"] }
          }
        },
        {
          "name": "Lister les animaux",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/animaux/animaux", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "animaux"] }
          }
        },
        {
          "name": "Voir une bande",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/animaux/bandes/{{bandeId}}", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "bandes", "{{bandeId}}"] }
          }
        },
        {
          "name": "Sortie collective de bande",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"typeMouvement\": \"SORTIE_VENTE\",\n  \"dateSortie\": \"2026-07-19\",\n  \"quantite\": 3,\n  \"poidsKg\": 280.0,\n  \"prixUnitaire\": 4.2,\n  \"motif\": \"Vente partielle\",\n  \"operateurNom\": \"Admin\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/animaux/bandes/{{bandeId}}/sortie", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "bandes", "{{bandeId}}", "sortie"] }
          }
        },
        {
          "name": "Échéances des bandes (fermeId)",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/animaux/bandes/echeances?fermeId={{fermeIdA}}&jours=30", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "bandes", "echeances"], "query": [ { "key": "fermeId", "value": "{{fermeIdA}}" }, { "key": "jours", "value": "30" } ] }
          }
        }
      ]
    },
    {
      "name": "6_Declarations_Bandes",
      "item": [
        {
          "name": "Déclarer une mortalité sur la bande",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('status 201', () => pm.response.to.have.status(201));", "const d = pm.response.json().data; if (d && d.id) pm.environment.set('declarationId', d.id);"] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"bandeId\": {{bandeId}},\n  \"type\": \"MORT\",\n  \"motif\": \"MALADIE\",\n  \"dateDeclaration\": \"2026-07-22\",\n  \"quantite\": 1,\n  \"poidsMoyenKg\": 25.5,\n  \"observations\": \"Porcin malade depuis 3 jours\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/animaux/declarations", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "declarations"] }
          }
        },
        {
          "name": "Lister toutes les déclarations (avec filtres)",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/animaux/declarations?fermeId={{fermeIdA}}&type=MORT&dateDebut=2026-07-01&dateFin=2026-07-31&page=0&size=20&sortBy=dateDeclaration&sortDir=desc", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "declarations"], "query": [ { "key": "fermeId", "value": "{{fermeIdA}}" }, { "key": "type", "value": "MORT" }, { "key": "dateDebut", "value": "2026-07-01" }, { "key": "dateFin", "value": "2026-07-31" }, { "key": "page", "value": "0" }, { "key": "size", "value": "20" }, { "key": "sortBy", "value": "dateDeclaration" }, { "key": "sortDir", "value": "desc" } ] }
          }
        },
        {
          "name": "Déclarer une vente sur la bande",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('status 201', () => pm.response.to.have.status(201));"] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"bandeId\": {{bandeId}},\n  \"type\": \"VENTE\",\n  \"motif\": \"GROSSISTE\",\n  \"dateDeclaration\": \"2026-07-23\",\n  \"quantite\": 3,\n  \"poidsMoyenKg\": 30.0,\n  \"prixUnitaire\": 4.5,\n  \"nomAcheteur\": \"Elevage Duval\",\n  \"telephoneAcheteur\": \"0612345678\",\n  \"localiteAcheteur\": \"Rennes\",\n  \"observations\": \"Vente 3 porcs engraissement\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/animaux/declarations", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "declarations"] }
          }
        },
        {
          "name": "Déclarer une réforme sur la bande",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('status 201', () => pm.response.to.have.status(201));"] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"bandeId\": {{bandeId}},\n  \"type\": \"REFORME\",\n  \"motif\": \"PRODUCTIVITE\",\n  \"dateDeclaration\": \"2026-07-23\",\n  \"quantite\": 1,\n  \"observations\": \"Trop faible croissance\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/animaux/declarations", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "declarations"] }
          }
        },
        {
          "name": "Lister les déclarations de la bande",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/animaux/declarations/bande/{{bandeId}}?page=0&size=20&sortBy=dateDeclaration&sortDir=desc", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "declarations", "bande", "{{bandeId}}"], "query": [ { "key": "page", "value": "0" }, { "key": "size", "value": "20" }, { "key": "sortBy", "value": "dateDeclaration" }, { "key": "sortDir", "value": "desc" } ] }
          }
        },
        {
          "name": "Récupérer les stats de la bande",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/animaux/declarations/bande/{{bandeId}}/stats", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "declarations", "bande", "{{bandeId}}", "stats"] }
          }
        },
        {
          "name": "Annuler une déclaration",
          "request": {
            "method": "PATCH",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "" },
            "url": { "raw": "{{baseUrl}}/api/animaux/declarations/{{declarationId}}/annuler?motif=Erreur%20saisie", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "declarations", "{{declarationId}}", "annuler"], "query": [ { "key": "motif", "value": "Erreur saisie" } ] }
          }
        },
        {
          "name": "Récupérer l'historique d'une déclaration",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{authToken}}" } ],
            "url": { "raw": "{{baseUrl}}/api/animaux/declarations/{{declarationId}}/historique", "host": ["{{baseUrl}}"], "path": ["api", "animaux", "declarations", "{{declarationId}}", "historique"] }
          }
        }
      ]
    }
  ]
